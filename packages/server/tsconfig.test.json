{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true
    },
    "include": [
        "src/**/*.test.ts",
        "src/**/*.integration.test.ts",
        "src/**/*.test.example.ts",
        "src/types/**/*.d.ts",
        "src/__mocks__/**/*.ts",
        "src/__tests__/**/*.ts",
        "vitest.setup.ts"
    ],
    "exclude": ["node_modules", "dist", "coverage", "coverage-integration"]
}
