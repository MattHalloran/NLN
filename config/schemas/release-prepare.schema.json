{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nln-release-prepare-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "receiptType",
    "receiptId",
    "status",
    "scope",
    "producer",
    "release",
    "startedAt",
    "finishedAt",
    "durationMilliseconds",
    "policy",
    "inputs",
    "checks",
    "outputs",
    "childReceipts",
    "result",
    "failure",
    "evidenceIndexSha256",
    "migrationClassification",
    "productionMutation"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "receiptType": { "const": "release-prepare" },
    "receiptId": { "type": "string" },
    "status": { "enum": ["planned", "failed"] },
    "scope": { "enum": ["fixture", "local"] },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "release": { "type": "object" },
    "startedAt": { "type": "string" },
    "finishedAt": { "type": "string" },
    "durationMilliseconds": { "type": "integer", "minimum": 0 },
    "policy": { "type": "object" },
    "inputs": { "type": "array" },
    "checks": { "type": "array" },
    "outputs": { "type": "array" },
    "childReceipts": { "type": "array" },
    "result": { "type": "object" },
    "failure": { "type": ["object", "null"] },
    "evidenceIndexSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "migrationClassification": {
      "enum": ["none", "backward-compatible", "bounded-window", "incompatible"]
    },
    "productionMutation": { "const": false }
  }
}
