    },
    {
      "alias": "validate:deployment-module-boundaries",
      "owner": "phase10",
      "effectClass": "local-read-only",
      "visibility": "internal",
      "rationale": "Prevents domain helpers and fixture adapters from coupling to production or network capabilities."
    },
    {
