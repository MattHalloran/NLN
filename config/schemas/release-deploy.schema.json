{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nln-release-deploy-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "receiptType", "receiptId", "status", "scope", "producer", "release", "startedAt", "finishedAt", "policy", "inputs", "checks", "outputs", "failure", "productionMutation", "userVisibleDowntimeBegan", "databaseMutationOccurred", "measuredDowntimeMilliseconds", "safestNextAction"],
  "properties": {
    "schemaVersion": { "const": 1 }, "receiptType": { "const": "release-deploy" }, "receiptId": { "type": "string" },
    "status": { "enum": ["planned", "success", "failed", "recovered", "blocked"] }, "scope": { "const": "fixture" }, "producer": { "type": "object" },
    "release": { "type": "object" }, "startedAt": { "type": "string" }, "finishedAt": { "type": "string" }, "policy": { "type": "object" },
    "inputs": { "type": "array" }, "checks": { "type": "array" }, "outputs": { "type": "array" }, "failure": { "type": ["object", "null"] },
    "productionMutation": { "const": false }, "userVisibleDowntimeBegan": { "type": "boolean" }, "databaseMutationOccurred": { "type": "boolean" },
    "measuredDowntimeMilliseconds": { "type": "integer", "minimum": 0 }, "safestNextAction": { "type": "string" }
  }
}
