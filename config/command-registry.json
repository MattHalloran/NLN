    {
      "alias": "validate:prisma-client",
      "owner": "quality",
      "effectClass": "local-fixture-mutation",
      "visibility": "internal",
      "rationale": "Safely stages the tracked schema and migrations in the ignored dist location used by package-scoped Prisma commands, then generates the local client so clean-checkout and CI integration validation share one preparation path."
    },
    {
      "alias": "validate:shared-build",
      "owner": "quality",
      "effectClass": "local-fixture-mutation",
      "visibility": "internal",
      "rationale": "Builds the tracked shared workspace before consumers are type-checked and tested so clean-checkout validation does not depend on stale dist output."
    },
    {
      "alias": "qualify:runtime-state-application-restore",
      "owner": "backup",
      "effectClass": "local-fixture-mutation",
      "visibility": "advanced",
      "rationale": "Converts a fully passed isolated production-style rehearsal and exact v2 archive into typed, archive-bound application restore evidence."
    },
    {
      "alias": "validate:deployment-traceability",
      "owner": "phase10",
      "effectClass": "local-read-only",
      "visibility": "internal",
      "rationale": "Proves receipt ownership and freezes current production entrypoint bytes."
    },
    {
      "alias": "runtime-state:backup:create-qualification",
