    {
      "alias": "validate:deployment-operational-objectives",
      "owner": "reliability",
      "effectClass": "local-read-only",
      "visibility": "internal",
      "rationale": "Rejects duplicated or conflicting freshness, RPO, RTO, restore cadence, and downtime limits."
    },
    {
      "alias": "release:state",
