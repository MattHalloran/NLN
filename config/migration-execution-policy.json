  "runtimeStateInventoryPath": "config/runtime-state-inventory.json",
  "requireTrustedGate": true,
  "requireSpecialPlanForHighRisk": true,
  "requireSpecialPlanForIncompatible": true,
  "applicationStartupMigrationRemovalApproved": false
}
