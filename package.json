{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "author": "New Life Nursery",
  "license": "MIT",
  "resolutions": {
    "babel-loader": "8.1.0",
    "vite": "5.4.20",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "uuid": "11.1.1",
    "cosmiconfig/yaml": "1.10.3"
  },
  "version": "3.0.4",
  "scripts": {
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "lint": "yarn workspaces run lint",
    "typecheck": "yarn workspaces run typecheck",
    "typecheck:test": "yarn workspaces run typecheck:test",
    "test": "yarn test:unit",
    "validate": "yarn validate:quick",
    "validate:quick": "yarn audit:repository-safety && yarn validate:trusted-manifest && yarn validate:runtime-state-inventory && yarn validate:runtime-state-backup-policy && yarn validate:runtime-state-remote-storage-policy && yarn typecheck && yarn typecheck:test && yarn lint && yarn test:unit && yarn test:scripts && yarn check:drift",
    "audit:repository-safety": "bash scripts/audit-public-repository-safety.sh",
    "validate:trusted-manifest": "node scripts/validate-trusted-manifest.mjs",
    "validate:trusted-receipt": "node scripts/verify-trusted-gate-receipt.mjs",
    "validate:runtime-state-inventory": "node scripts/validate-runtime-state-inventory.mjs",
    "validate:runtime-state-backup-policy": "node scripts/validate-runtime-state-backup-policy.mjs",
    "validate:runtime-state-remote-storage-policy": "node scripts/validate-runtime-state-remote-storage-policy.mjs",
    "publish:runtime-state-backup": "node scripts/publish-runtime-state-backup.mjs",
    "test:runtime-state-s3-emulator": "RUN_RUNTIME_STATE_S3_EMULATOR=1 bats scripts/tests/runtime-state-s3-emulator-integration.bats",
    "check:runtime-state-backup-freshness": "node scripts/check-runtime-state-backup-freshness.mjs",
    "cleanup:runtime-state-remote-backups": "node scripts/cleanup-runtime-state-remote-backups.mjs",
    "capture:runtime-state-manifest": "node scripts/capture-runtime-state-manifest-v2.mjs",
    "validate:runtime-state-backup": "node scripts/runtime-state-manifest-v2.mjs verify",
    "validate:runtime-state-archive": "node scripts/runtime-state-archive-v2.mjs verify",
    "validate:runtime-state-backup-compatible": "node scripts/verify-runtime-state-backup.mjs",
    "validate:runtime-state-database": "node scripts/verify-runtime-state-database-invariants.mjs",
    "validate:runtime-state-database-restore": "node scripts/verify-runtime-state-database-restore.mjs",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "validation:receipt": "node scripts/validation-receipt.mjs",
    "validate:trusted": "bash scripts/validate-trusted.sh",
    "validate:browser": "yarn workspace @local/shared build && yarn workspace ui build && yarn test:pwa && yarn test:a11y && yarn test:e2e:public && yarn test:visual && yarn test:e2e:admin && yarn test:e2e:production && yarn test:e2e:production-local",
    "validate:full": "yarn validate:quick && yarn test:integration && yarn validate:browser",
    "validate:release": "bash scripts/validate-release.sh",
    "validate:ci": "yarn validate:full",
    "deploy:readiness": "./scripts/deploy-readiness.sh",
    "check:pwa-headers": "./scripts/check-pwa-headers.sh",
    "test:unit": "yarn workspace @local/shared test && yarn workspace ui test && yarn workspace server test:unit",
    "test:integration": "yarn workspace server test:integration",
    "test:scripts": "scripts/tests/__runTests.sh",
    "check:drift": "scripts/check-env-defaults.sh && scripts/check-source-drift.sh && scripts/check-test-quality.sh && scripts/check-migrations.sh",
    "test:server": "yarn workspace server test",
    "test:ui": "yarn workspace ui test",
    "test:e2e": "yarn test:e2e:smoke",
    "test:e2e:smoke": "playwright test --config playwright.config.ts",
    "test:e2e:public": "playwright test --config playwright.public.config.ts",
    "test:e2e:production": "playwright test --config playwright.production.config.ts",
    "test:e2e:production-local": "bash scripts/start-local-production.sh && playwright test --config playwright.production-local.config.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:e2e:stable": "yarn test:e2e:admin",
    "test:e2e:admin": "playwright test --config playwright.admin.config.ts",
    "test:a11y": "playwright test --config playwright.accessibility.config.ts",
    "test:pwa": "playwright test --config playwright.pwa.config.ts",
    "test:e2e:legacy": "playwright test --config playwright.legacy.config.ts",
    "test:e2e:full": "playwright test --config playwright.full.config.ts",
    "test:e2e:all": "yarn test:e2e:full",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3001",
    "smoke-test": "npx tsx scripts/smoke-test-admin.ts",
    "smoke:public": "node scripts/public-smoke.mjs",
    "lighthouse": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp lhci autorun",
    "lighthouse:local": "./scripts/lighthouse-local.sh",
    "lighthouse:prod": "./scripts/lighthouse-prod.sh",
    "lighthouse:collect": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp lhci collect",
    "lighthouse:assert": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp lhci assert",
    "lighthouse:open": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp lhci open"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vitest": "^0.5.4"
  },
  "dependencies": {}
}
