{
  "schemaVersion": 1,
  "policyId": "nln-phase9-disaster-recovery-v1",
  "productionIntegrationEnabled": false,
  "fixtureOnly": true,
  "networkAccessAllowed": false,
  "requiredPostgresMajor": 13,
  "maximumRtoMilliseconds": 7200000,
  "maximumRpoMilliseconds": 3600000,
  "requiredIndependentInputs": [
    "immutable-release-bundle",
    "encrypted-remote-backup",
    "recovery-identity",
    "recovery-configuration"
  ],
  "requiredChecks": [
    "clean-host",
    "repository-unavailable",
    "network-denied",
    "release-verified",
    "backup-decrypted",
    "backup-verified",
    "postgres-compatible",
    "database-invariants",
    "uploads-and-assets",
    "migrations",
    "authentication-and-sessions",
    "queues",
    "public-pages",
    "admin-read-write",
    "application-logs"
  ],
  "destructiveBoundaries": [
    "before-runtime-initialization",
    "before-database-restore",
    "before-application-activation"
  ],
  "emergencyEvidence": {
    "requiredBeforeDestructiveRestore": true,
    "requireLogicalDump": true,
    "requireCriticalRuntimeCopies": true,
    "allowFixtureDisasterOverride": true,
    "retainUntilRecoveryClosure": true,
    "automaticDeletionAllowed": false
  },
  "salvage": {
    "requireManualReconciliationPlan": true,
    "requireSourceAndRestoredFacts": true,
    "requireConflictAndAppliedWriteCounts": true,
    "automaticMergeAllowed": false
  },
  "qualification": {
    "requiredSuccessfulDrills": 2,
    "requireFailureInjectionAtEveryBoundary": true,
    "ciFixtureDrillQualifiesRealBackup": false,
    "requireOwnerOnlyEvidence": true,
    "allowEvidenceOverwrite": false
  }
}
